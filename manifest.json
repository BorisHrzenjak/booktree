{
  "manifest_version": 3,
  "name": "BookTree",
  "description": "Open Chrome bookmarks as a compact, searchable tree graph.",
  "version": "0.1.0",
  "permissions": ["bookmarks", "tabs"],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open BookTree",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
